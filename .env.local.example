# Supabase (frontend + auth)
# NEXT_PUBLIC_SUPABASE_ANON_KEY = Publishable key (sb_publishable_...)
# NUNCA uses aquí la Secret key (sb_secret_...).
NEXT_PUBLIC_SUPABASE_URL=https://<tu-proyecto>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_<...>

# Google Sheets API (service account)
GOOGLE_SERVICE_ACCOUNT_EMAIL=<sa>@<proyecto>.iam.gserviceaccount.com
# Pega la private_key del JSON del service account, con \n literales o saltos reales.
# En Vercel, simplemente pega el valor multilinea de "private_key" tal cual.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ID del Google Sheet (de la URL: /spreadsheets/d/<ID>/edit)
SHEET_ID=12fO8p5KMzOlzzMxZHQXt3_AFa0Bn0w28pvySSCFAN2c
# Nombre/rango de la pestaña a leer (ajusta según tu Sheet)
SHEET_RANGE=Gantt!A1:AT200
